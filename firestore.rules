
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // --- Collection Rules ---

    // Public lookup for eligibility status
    match /farmerProfiles/{profileId} {
      // Allow list/query lookup only if specific unique fields are provided in the query
      allow list: if true; 
      allow get: if true;
      allow create, update, delete: if isAdmin();
    }

    match /subsidyCategories/{subsidyCategoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId}/farmerProfile/{profileId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/applications/{applicationId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.farmerProfileId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.farmerProfileId == resource.data.farmerProfileId;
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/documents/{documentId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.farmerProfileId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.farmerProfileId == resource.data.farmerProfileId;
      allow delete: if isExistingOwner(userId);
    }
  }
}
